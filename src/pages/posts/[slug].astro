---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import AuthorCard from '../../components/AuthorCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const text = post.body ?? '';
const chineseChars = (text.match(/[一-鿿]/g) ?? []).length;
const englishWords = (text.match(/[a-zA-Z]+/g) ?? []).length;
const minutes = Math.max(1, Math.ceil(chineseChars / 400 + englishWords / 200));
const readingTime = `約 ${minutes} 分鐘`;
---

<BlogLayout title={post.data.title} activeSlug={post.id} description={post.data.description} date={post.data.date instanceof Date ? post.data.date.toISOString() : String(post.data.date ?? '')}>
  <article>
    <div style="margin-bottom: 32px;">
      <h1 style="
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.3;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
      ">
        {post.data.title}
      </h1>
      <div style="display: flex; gap: 12px; font-size: 13px; color: var(--muted); align-items: center; flex-wrap: wrap;">
        <span>{post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span>{readingTime}</span>
        {post.data.tags.map(tag => (
          <a href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}tags/${tag}`} style="color: #60a5fa; text-decoration: none; font-size: 13px;">#{tag}</a>
        ))}
      </div>
    </div>

    <div class="article-body">
      <Content />
    </div>
    <AuthorCard />
  </article>
</BlogLayout>

<style>
  .article-body {
    color: var(--text);
    font-size: 16px;
    line-height: 1.8;
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  }

  /* H1-H6 (body = 16px) */
  .article-body :global(h1) { font-size: 2rem;      font-weight: 700; margin: 2.5rem 0 1rem;    letter-spacing: -0.02em;  line-height: 1.25; color: var(--text); }
  .article-body :global(h2) { font-size: 1.75rem;   font-weight: 700; margin: 2.25rem 0 0.75rem; letter-spacing: -0.015em; line-height: 1.3;  color: var(--text); }
  .article-body :global(h3) { font-size: 1.5rem;    font-weight: 600; margin: 2rem 0 0.5rem;    letter-spacing: -0.01em;  line-height: 1.35; color: var(--text); }
  .article-body :global(h4) { font-size: 1.375rem;  font-weight: 600; margin: 1.75rem 0 0.5rem; line-height: 1.4;         color: var(--text); }
  .article-body :global(h5) { font-size: 1.25rem;   font-weight: 600; margin: 1.5rem 0 0.5rem;  line-height: 1.4;         color: var(--text); }
  .article-body :global(h6) { font-size: 1.125rem;  font-weight: 600; margin: 1.25rem 0 0.5rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text); }

  .article-body :global(p)  { margin: 0 0 1rem; }
  .article-body :global(a)  { color: var(--text); text-decoration: underline; text-underline-offset: 3px; }
  .article-body :global(a:hover) { opacity: 0.7; }

  .article-body :global(strong) { font-weight: 600; }
  .article-body :global(em)     { font-style: italic; }
  .article-body :global(del)    { text-decoration: line-through; opacity: 0.9; }

  .article-body :global(code:not(pre code)) {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.9em;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 0.4rem;
    padding: 1px 0.25rem;
    color: #e06c75;
    white-space: pre-wrap;
    font-variant-ligatures: none;
  }

  .article-body :global(.expressive-code) {
    margin: 1.25rem 0;
    font-size: 13px;
  }

  .article-body :global(blockquote) {
    position: relative;
    margin: 1.5rem 0;
    padding: 20px 20px 20px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-style: italic;
    color: var(--text);
  }

  .article-body :global(blockquote)::before {
    content: '\201C';
    position: absolute;
    left: 14px;
    top: 10px;
    font-size: 2.5rem;
    line-height: 1;
    color: #60a5fa;
    font-style: normal;
    font-family: Georgia, serif;
  }

  .article-body :global(blockquote p) { margin: 0; }

  .article-body :global(ul) {
    list-style-type: disc;
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .article-body :global(ul ul) { list-style-type: circle; margin: 4px 0; }
  .article-body :global(ul ul ul) { list-style-type: square; }

  .article-body :global(ol) {
    list-style-type: decimal;
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) { margin-bottom: 4px; }

  .article-body :global(li input[type="checkbox"]) {
    margin-right: 6px;
    accent-color: var(--text);
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin: 1.25rem 0;
  }

  .article-body :global(th) {
    text-align: left;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding: 6px 12px 6px 0;
  }

  .article-body :global(td) {
    border-bottom: 1px solid var(--border);
    padding: 8px 12px 8px 0;
    vertical-align: top;
  }

  .article-body :global(hr) {
    border: none;
    height: 1px;
    margin: 2rem 0;
    background: linear-gradient(to right, transparent, var(--border) 20%, var(--border) 80%, transparent);
  }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
</style>
