---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import TableOfContents from "../../components/TableOfContents.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const text = post.body ?? "";
const chineseChars = (text.match(/[一-鿿]/g) ?? []).length;
const englishWords = (text.match(/[a-zA-Z]+/g) ?? []).length;
const minutes = Math.max(1, Math.ceil(chineseChars / 400 + englishWords / 200));
const readingTime = `約 ${minutes} 分鐘`;
---

<BlogLayout
  title={post.data.title}
  activeSlug={post.id}
  description={post.data.description}
  date={post.data.date instanceof Date
    ? post.data.date.toISOString()
    : String(post.data.date ?? "")}
>
  <article>
    <div class="article-header">
      <h1 class="article-title">
        {post.data.title}
      </h1>
      <div class="article-meta">
        <span
          >{
            post.data.date.toLocaleDateString("zh-TW", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }</span
        >
        <span>{readingTime}</span>
        {
          post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="meta-link">
              #{tag}
            </a>
          ))
        }
      </div>
    </div>

    <div class="article-body">
      <Content />
    </div>
    <AuthorCard />
  </article>
  <TableOfContents headings={headings} />
</BlogLayout>

<style>
  .article-header {
    margin-bottom: 34px;
  }

  .article-title {
    font-size: 2.125rem;
    font-weight: 650;
    color: var(--heading);
    line-height: 1.25;
    letter-spacing: 0;
    text-wrap: pretty;
    margin: 0 0 14px;
  }

  .article-meta {
    display: flex;
    gap: 10px 12px;
    font-size: 14px;
    color: var(--muted);
    align-items: center;
    flex-wrap: wrap;
  }

  .article-meta a {
    font-size: inherit;
  }

  .article-body {
    color: var(--article-text);
    font-size: 18px;
    line-height: 1.8;
    font-family: inherit;
    text-wrap: pretty;
  }

  /* H1-H6 (body = 18px) */
  .article-body :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--heading);
  }
  .article-body :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 2.25rem 0 0.75rem;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--heading);
  }
  .article-body :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.35;
    color: var(--heading);
  }
  .article-body :global(h4) {
    font-size: 1.375rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    line-height: 1.4;
    color: var(--heading);
  }
  .article-body :global(h5) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    line-height: 1.4;
    color: var(--heading);
  }
  .article-body :global(h6) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 1.25rem 0 0.5rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--heading);
  }

  .article-body :global(p) {
    margin: 0 0 1.2rem;
  }
  .article-body :global(a) {
    color: var(--heading);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body :global(a:hover) {
    opacity: 0.7;
  }

  .article-body :global(strong) {
    font-weight: 600;
    color: var(--heading);
  }
  .article-body :global(em) {
    font-style: italic;
  }
  .article-body :global(del) {
    text-decoration: line-through;
    opacity: 0.9;
  }

  .article-body :global(code:not(pre code)) {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.95em;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 0.4rem;
    padding: 1px 0.25rem;
    color: var(--code-inline);
    white-space: pre-wrap;
    font-variant-ligatures: none;
  }

  .article-body :global(.expressive-code) {
    --ec-codeFg: var(--code-text) !important;
    --ec-gtrFg: var(--code-muted) !important;
    --ec-gtrHlFg: var(--code-text) !important;
    --ec-lineNumbers-fg: var(--code-muted) !important;
    --ec-lineNumbers-hlFg: var(--code-text) !important;
    margin: 1.25rem 0;
    font-size: 16px;
  }

  .article-body :global(.expressive-code pre[data-language="plaintext"] .ec-line span[style^="--"]) {
    --0: var(--code-text) !important;
    --1: var(--code-text) !important;
  }

  .article-body :global(blockquote) {
    position: relative;
    margin: 1.5rem 0;
    padding: 20px 20px 20px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-style: italic;
    color: var(--article-text);
  }

  .article-body :global(blockquote)::before {
    content: "\201C";
    position: absolute;
    left: 14px;
    top: 10px;
    font-size: 2.5rem;
    line-height: 1;
    color: var(--accent);
    font-style: normal;
    font-family: Georgia, serif;
  }

  .article-body :global(blockquote p) {
    margin: 0;
  }

  .article-body :global(ul) {
    list-style-type: disc;
    margin: 0 0 1.25rem;
    padding-left: 1.35rem;
  }

  .article-body :global(ul ul) {
    list-style-type: circle;
    margin: 0.35rem 0;
  }
  .article-body :global(ul ul ul) {
    list-style-type: square;
  }

  .article-body :global(ol) {
    list-style-type: decimal;
    margin: 0 0 1.25rem;
    padding-left: 1.35rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.45rem;
  }

  .article-body :global(li input[type="checkbox"]) {
    margin-right: 6px;
    accent-color: var(--text);
  }

  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 16px;
    margin: 1.25rem 0;
  }

  .article-body :global(th) {
    text-align: left;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding: 6px 12px 6px 0;
  }

  .article-body :global(td) {
    border-bottom: 1px solid var(--border);
    padding: 8px 12px 8px 0;
    vertical-align: top;
  }

  .article-body :global(hr) {
    border: none;
    height: 1px;
    margin: 2rem 0;
    background: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--muted) 40%, transparent) 20%,
      color-mix(in srgb, var(--muted) 40%, transparent) 80%,
      transparent
    );
  }

  .article-body :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .article-header {
      margin-bottom: 32px;
    }

    .article-title {
      line-height: 1.22;
      margin-bottom: 16px;
    }

    .article-meta {
      font-size: 14px;
      line-height: 1.45;
    }

    .article-body {
      font-size: 19px;
      line-height: 1.9;
    }

    .article-body :global(h1) {
      font-size: 2rem;
      margin: 2.6rem 0 1rem;
    }

    .article-body :global(h2) {
      font-size: 1.75rem;
      margin: 2.5rem 0 0.85rem;
    }

    .article-body :global(h3) {
      font-size: 1.45rem;
      margin: 2.1rem 0 0.7rem;
    }

    .article-body :global(p) {
      margin-bottom: 1.3rem;
    }

    .article-body :global(ul),
    .article-body :global(ol) {
      margin-bottom: 1.35rem;
      padding-left: 1.25rem;
    }

    .article-body :global(li) {
      margin-bottom: 0.5rem;
      padding-left: 0.1rem;
    }

    .article-body :global(blockquote) {
      margin: 1.75rem 0;
      padding: 18px 18px 18px 42px;
    }

    .article-body :global(table) {
      font-size: 14px;
    }

    .article-body :global(.expressive-code) {
      font-size: 14px;
      margin: 1.5rem 0;
    }
  }
</style>
