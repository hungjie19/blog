---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout title={post.data.title} activeSlug={post.id}>
  <article>
    <div style="margin-bottom: 32px;">
      <h1 style="
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.3;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
      ">
        {post.data.title}
      </h1>
      <div style="display: flex; gap: 12px; font-size: 13px; color: var(--muted); align-items: center; flex-wrap: wrap;">
        <span>{post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        {post.data.tags.map(tag => (
          <span style="
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1px 8px;
            font-size: 11px;
          ">{tag}</span>
        ))}
      </div>
    </div>

    <div class="prose">
      <Content />
    </div>
  </article>
</BlogLayout>

<style>
  .prose {
    color: var(--text);
    font-size: 15px;
    line-height: 1.75;
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  }

  .prose :global(h2) { font-size: 1.25rem; font-weight: 600; margin: 2rem 0 0.75rem; letter-spacing: -0.01em; }
  .prose :global(h3) { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(h4) { font-size: 1rem; font-weight: 600; margin: 1.25rem 0 0.5rem; color: var(--muted); }

  .prose :global(p)  { margin: 0 0 1rem; }
  .prose :global(a)  { color: var(--text); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { opacity: 0.7; }

  .prose :global(strong) { font-weight: 600; }
  .prose :global(em)     { font-style: italic; }
  .prose :global(del)    { color: var(--muted); }

  .prose :global(code:not(pre code)) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 6px;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
    overflow-x: auto;
    margin: 1.25rem 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.6;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--border);
    margin: 1.25rem 0;
    padding: 4px 0 4px 16px;
    color: var(--muted);
    font-style: italic;
  }

  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) { margin-bottom: 4px; }

  .prose :global(li input[type="checkbox"]) {
    margin-right: 6px;
    accent-color: var(--text);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin: 1.25rem 0;
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding: 6px 12px 6px 0;
  }

  .prose :global(td) {
    border-bottom: 1px solid var(--border);
    padding: 8px 12px 8px 0;
    vertical-align: top;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
</style>
