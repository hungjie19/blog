---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BlogLayout>
  <div class="feed">
    {posts.map((post, i) => (
      <article class="feed-item" data-index={i}>
        <a href={`${base}posts/${post.id}`} class="feed-link">
          <span class="feed-title">{post.data.title}</span>

          {post.data.description && (
            <p class="feed-desc">{post.data.description}</p>
          )}

          {post.data.image && (
            <img class="feed-image" src={post.data.image} alt={post.data.title} loading="lazy" />
          )}
        </a>

        <div class="feed-meta">
          <time>{post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '-')}</time>
          {post.data.tags.length > 0 && (
            <div class="feed-tags">
              {post.data.tags.map(tag => (
                <a href={`${base}tags/${tag}`} class="feed-tag">#{tag}</a>
              ))}
            </div>
          )}
        </div>
      </article>
    ))}
  </div>
</BlogLayout>

<style>
  .feed { display: flex; flex-direction: column; }

  .feed-item { padding: 24px 0; }

  .feed-link {
    display: block;
    text-decoration: none;
    color: var(--text);
  }

  /* 1. 標題永遠是入口 */
  .feed-title {
    display: block;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 8px;
  }

  .feed-link:hover .feed-title { text-decoration: underline; }

  /* 2. description 緊貼標題，當判斷輔助 */
  .feed-desc {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0 0 8px;
  }

  .feed-image {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border);
    margin: 0 0 12px;
    display: block;
  }

  /* 3. date / tags 是 metadata，放最後 */
  .feed-meta {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-size: 14px;
  }

  time {
    font-size: 14px;
    color: var(--muted);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .feed-tags {
    display: flex;
    gap: 8px;
  }

  .feed-tag {
    color: var(--accent-muted);
    text-decoration: none;
  }
  .feed-tag:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .feed-desc {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

  }

  .feed-item:not(:last-child) {
    border-bottom: 1px solid var(--border);
  }

  .feed-item {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1), transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feed-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const items = document.querySelectorAll('.feed-item');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const i = Number(el.dataset.index);
          setTimeout(() => el.classList.add('visible'), i * 80);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.05 }
  );
  items.forEach(item => observer.observe(item));
</script>
