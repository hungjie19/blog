---
import BlogLayout from '../layouts/BlogLayout.astro';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BlogLayout title="About">
  <div class="about-wrapper">
    <img
      src={`${base}author-card-about.jpg`}
      alt="Jasper Hung coworking with AI"
      class="about-hero"
    />

    <div class="about-identity">
      <h1 class="about-name">Jasper Hung</h1>
    </div>

    <div class="about-bio">
      <p>Software Engineer，從前端出發，對網站的設計與互動有一定的品味，主要用 React / TypeScript 做產品。</p>
      <p>相信 AI 協作是接下來最值得投入的事。不是把 AI 當工具用，而是把 context 給它、一起討論、自己做決定——讓我可以同時消化設計、後端、PM 三邊的 constraint，做出更完整的思考。</p>
      <p>這裡記錄協作的實戰片段：一個 bug 怎麼從前端止血到後端根治、一個需求怎麼拆成可執行的 spec、以及那些 AI 一針見血說中我沒想到的地方。</p>
    </div>

    <div class="about-links">
      <a href="https://github.com/hungjie19" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</BlogLayout>

<style>
  .about-wrapper {
    max-width: 600px;
    padding-top: 16px;
  }

  .about-hero {
    width: 100%;
    border-radius: 14px;
    border: 1px solid var(--border);
    display: block;
    margin-bottom: 28px;
  }

  .about-identity {
    margin-bottom: 24px;
  }

  .about-name {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }

.about-bio {
    color: var(--text);
    font-size: 15px;
    line-height: 1.8;
  }

  .about-bio p {
    margin: 0 0 1rem;
  }

  .about-links {
    display: flex;
    gap: 16px;
    margin-top: 24px;
  }

  .about-links a {
    font-size: 14px;
    color: #60a5fa;
    text-decoration: none;
  }

  .about-links a:hover {
    text-decoration: underline;
  }
</style>
