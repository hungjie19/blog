---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="404 — 找不到這頁">
  <div class="flex min-h-[60vh] flex-col items-center justify-center gap-4 text-center">
    <p class="m-0 text-8xl font-bold leading-none text-border">404</p>
    <p class="m-0 text-lg text-text">找不到這個頁面</p>
    <p class="m-0 text-sm text-muted">可能是連結失效，或從來就不存在。</p>
    <a href="/" class="mt-2 text-sm text-accent no-underline hover:underline">← 回首頁</a>
  </div>
</BlogLayout>
