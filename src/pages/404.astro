---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="404 — 找不到這頁">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center; gap: 16px;">
    <p style="font-size: 6rem; font-weight: 700; color: var(--border); line-height: 1; margin: 0;">404</p>
    <p style="font-size: 1.125rem; color: var(--text); margin: 0;">找不到這個頁面</p>
    <p style="font-size: 0.875rem; color: var(--muted); margin: 0;">可能是連結失效，或從來就不存在。</p>
    <a href="/" style="margin-top: 8px; font-size: 14px; color: var(--accent); text-decoration: none;">← 回首頁</a>
  </div>
</BlogLayout>
