---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getTags } from '../../lib/tags';

const posts = await getCollection('blog');
const tags = getTags(posts);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BlogLayout title="Tags">
  <div>
    <div class="mb-8">
      <div class="mb-2 text-[13px] text-muted">
        <a href={base} class="text-muted no-underline hover:text-text">所有文章</a>
        <span class="mx-1.5">›</span>
        <span>標籤</span>
      </div>
      <h1 class="m-0 text-2xl font-bold tracking-[-0.01em]">Tags</h1>
      <p class="m-0 mt-2 text-[13px] text-muted">{tags.length} 個標籤</p>
    </div>

    <div class="tags-cloud">
      {tags.map(t => (
        <a href={`${base}tags/${t.label}`} class="tag-pill">
          <span class="tag-name">#{t.label}</span>
          {t.count > 1 && <span class="tag-count">{t.count}</span>}
        </a>
      ))}
    </div>
  </div>
</BlogLayout>

<style>
  /* wrap 的 chips：count 緊貼 tag、無底線、無滿版分隔列 */
  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    background: var(--surface);
    text-decoration: none;
    transition: background 150ms ease;
  }

  .tag-pill:hover { background: var(--border); }

  .tag-name {
    font-size: 14px;
    color: var(--accent-muted);
  }

  .tag-count {
    font-size: 12px;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
</style>
