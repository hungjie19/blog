---
import { getCollection } from 'astro:content';
import { getTags } from '../lib/tags';
import '../styles/global.css';

interface Props {
  title?: string;
  activeSlug?: string;
  description?: string;
  date?: string;
}

const { title, activeSlug, description, date } = Astro.props;

const siteUrl = 'https://jasperhung.dev';
const pageTitle = title ? `${title} — Jasper Hung` : 'Jasper Hung';
const pageDescription = description ?? 'Jasper 與 AI 協作的實戰紀錄：工程、產品、個人品牌。';
const canonicalUrl = activeSlug ? `${siteUrl}/posts/${activeSlug}` : siteUrl;
const ogImageUrl = activeSlug ? `${siteUrl}/og/${activeSlug}.png` : `${siteUrl}/og/default.png`;

const jsonLd = activeSlug
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description: pageDescription,
      datePublished: date,
      author: { '@type': 'Person', name: 'Jasper Hung', url: siteUrl },
      url: canonicalUrl,
    })
  : JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Jasper Hung',
      url: siteUrl,
      author: { '@type': 'Person', name: 'Jasper Hung' },
    });
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) =>
  new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const allTags = getTags(sorted);

const navLinkClass =
  'block overflow-hidden text-ellipsis whitespace-nowrap rounded-md px-3 py-1.5 text-sm no-underline transition-colors duration-100 hover:bg-surface hover:text-text';
const iconButtonClass =
  'flex cursor-pointer items-center rounded p-1 text-muted no-underline hover:bg-surface hover:text-text';
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href={`${base}favicon.ico`} sizes="32x32" />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <!-- 防閃爍：在 CSS 載入前先套用 theme class + EC data-theme -->
  <script is:inline>
    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = saved ?? (prefersDark ? 'dark' : 'light');
    document.documentElement.classList.add(theme);
    if (theme === 'light') document.documentElement.setAttribute('data-theme', 'github-light');
  </script>
  <link rel="alternate" type="application/rss+xml" title="Jasper Hung" href={`${siteUrl}/rss.xml`} />

  <!-- Open Graph -->
  <meta property="og:type" content={activeSlug ? 'article' : 'website'} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Jasper Hung" />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={pageTitle} />
  {date && <meta property="article:published_time" content={date} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- JSON-LD -->
  <script is:inline type="application/ld+json" set:html={jsonLd} />

  <!-- Raw markdown alternate (AEO: AI crawlers can read plain markdown directly) -->
  {activeSlug && <link rel="alternate" type="text/markdown" href={`${canonicalUrl}.md`} title="Raw Markdown" />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="flex h-dvh overflow-hidden bg-bg text-text">
  {activeSlug && <div id="reading-progress" class="pointer-events-none fixed left-0 top-0 z-[1000] h-[3px] w-0 bg-accent transition-[width] duration-[80ms] ease-linear"></div>}

  <div id="sidebar-backdrop"></div>

  <!-- Sidebar -->
  <aside
    id="sidebar"
    class="flex w-[260px] shrink-0 flex-col border-r border-border bg-sidebar transition-transform duration-200 ease-in-out"
  >
    <!-- Blog name -->
    <div class="shrink-0 border-b border-border">
      <a
        href={base}
        class="block p-4 no-underline"
      >
        <div class="text-base font-bold leading-[1.2] tracking-[-0.02em] text-text">Jasper Hung</div>
        <div class="mt-[3px] text-[13px] font-medium text-muted">Coworking with AI</div>
      </a>
    </div>

    <!-- Article list -->
    <nav class="flex-1 overflow-y-auto px-1 py-2">
      <a
        href={`${base}about`}
        class={`${navLinkClass} bg-transparent text-muted`}
      >About</a>
      <div class="px-3 pb-1 pt-2 text-xs uppercase tracking-[0.06em] text-muted">Posts</div>
      {sorted.map(post => (
        <a
          href={`${base}posts/${post.id}`}
          class={`${navLinkClass} ${activeSlug === post.id ? 'bg-border text-text' : 'bg-transparent text-muted'}`}
        >
          {post.data.title}
        </a>
      ))}
    </nav>

    <!-- Tags -->
    {allTags.length > 0 && (
      <div class="shrink-0 border-t border-border p-3">
        <a href={`${base}tags`} class="tags-heading">Tags</a>
        <div class="sidebar-tags">
          {allTags.map(t => (
            <a href={`${base}tags/${t.label}`} class="meta-link sidebar-tag text-sm">
              #{t.label}
            </a>
          ))}
        </div>
      </div>
    )}
  </aside>

  <!-- Main -->
  <div class="flex min-w-0 flex-1 flex-col overflow-hidden">

    <!-- Topbar -->
    <header class="flex h-12 shrink-0 items-center gap-3 border-b border-border px-4">
      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="hidden shrink-0 cursor-pointer border-0 bg-transparent p-1 text-muted"
        aria-label="Menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <!-- Mobile blog title (visible only on mobile) -->
      <a
        id="mobile-blog-title"
        href={base}
        class="hidden shrink-0 text-[15px] font-bold tracking-[-0.02em] text-text no-underline"
      >
        Jasper Hung
      </a>

      <!-- Title (article title, desktop only) -->
      <span id="topbar-title" class="flex-1 overflow-hidden text-ellipsis whitespace-nowrap text-sm text-muted">
        {title ?? ''}
      </span>

      <!-- Icons -->
      <div class="flex shrink-0 items-center gap-2">
        <button
          id="theme-btn"
          class={`${iconButtonClass} border-0 bg-transparent`}
          title="切換深色／淺色"
          aria-label="切換主題"
        >
          <!-- moon (dark mode) -->
          <svg id="icon-moon" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <!-- sun (light mode) -->
          <svg id="icon-sun" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
        {title && (
          <>
            <span class="h-4 w-px bg-border" />
            <button
              id="share-btn"
              class={`${iconButtonClass} border-0 bg-transparent`}
              title="複製連結"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </button>
            <a
              href={activeSlug ? `${base}posts/${activeSlug}.md` : '#'}
              class={iconButtonClass}
              title="Raw Markdown"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            </a>
          </>
        )}
        <a
          href={`${base}rss.xml`}
          class={iconButtonClass}
          title="RSS Feed"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 overflow-y-auto [-webkit-overflow-scrolling:touch]">
      <div class="content-wrapper">
        <slot />
      </div>
    </main>
  </div>

</body>
</html>

<style>
  /* RWD content width */
  .content-wrapper {
    width: 100%;
    max-width: 740px;
    margin: 0 auto;
    padding: 34px 24px 48px;
  }

  @media (min-width: 640px) {
    .content-wrapper { padding: 40px 28px; }
  }

  @media (min-width: 1024px) {
    .content-wrapper { padding: 48px 32px; }
  }

  #sidebar { display: flex; }

  @media (max-width: 768px) {
    #sidebar {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      height: 100%;
      z-index: 100;
    }
    #sidebar.open { display: flex; }
    #menu-btn { display: flex !important; }
    #mobile-blog-title { display: block !important; flex: 1; }
    #topbar-title { display: none; }
    #sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 99;
    }
    #sidebar-backdrop.open { display: block; }
  }

  /* Sidebar Tags: 標題可點 → /tags */
  .tags-heading {
    display: block;
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
    text-decoration: none;
  }
  .tags-heading:hover { color: var(--text); }

  /* 最多 3 行：3*21(line-height) + 2*6(gap) = 75px，超出隱藏 */
  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 6px;
    max-height: 75px;
    overflow: hidden;
  }
  .sidebar-tag { line-height: 21px; }
</style>

<script>
  // theme toggle
  function isDark() {
    return document.documentElement.classList.contains('dark') ||
      (!document.documentElement.classList.contains('light') &&
        window.matchMedia('(prefers-color-scheme: dark)').matches);
  }
  function updateThemeIcon() {
    const dark = isDark();
    (document.getElementById('icon-moon') as HTMLElement).style.display = dark ? 'block' : 'none';
    (document.getElementById('icon-sun') as HTMLElement).style.display = dark ? 'none' : 'block';
  }
  document.getElementById('theme-btn')?.addEventListener('click', () => {
    const dark = isDark();
    const next = dark ? 'light' : 'dark';
    document.documentElement.classList.remove('dark', 'light');
    document.documentElement.classList.add(next);
    if (next === 'light') {
      document.documentElement.setAttribute('data-theme', 'github-light');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }
    localStorage.setItem('theme', next);
    updateThemeIcon();
  });
  updateThemeIcon();

  document.getElementById('share-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
  });

  function toggleSidebar() {
    document.getElementById('sidebar')?.classList.toggle('open');
    document.getElementById('sidebar-backdrop')?.classList.toggle('open');
  }
  document.getElementById('menu-btn')?.addEventListener('click', toggleSidebar);
  document.getElementById('sidebar-backdrop')?.addEventListener('click', toggleSidebar);

  const main = document.querySelector('main');
  const bar = document.getElementById('reading-progress');
  if (main && bar) {
    main.addEventListener('scroll', () => {
      const { scrollTop, scrollHeight, clientHeight } = main;
      const pct = scrollHeight <= clientHeight ? 100 : (scrollTop / (scrollHeight - clientHeight)) * 100;
      (bar as HTMLElement).style.width = pct + '%';
    });
  }
</script>
