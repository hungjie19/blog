---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title?: string;
  activeSlug?: string;
  description?: string;
  date?: string;
}

const { title, activeSlug, description, date } = Astro.props;

const siteUrl = 'https://jasperhung.dev';
const pageTitle = title ? `${title} — Jasper cowork with AI` : 'Jasper cowork with AI';
const pageDescription = description ?? 'Jasper 與 AI 協作的實戰紀錄：工程、產品、個人品牌。';
const canonicalUrl = activeSlug ? `${siteUrl}/posts/${activeSlug}` : siteUrl;

const jsonLd = activeSlug
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description: pageDescription,
      datePublished: date,
      author: { '@type': 'Person', name: 'Jasper Hung', url: siteUrl },
      url: canonicalUrl,
    })
  : JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Jasper cowork with AI',
      url: siteUrl,
      author: { '@type': 'Person', name: 'Jasper Hung' },
    });
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) =>
  new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

function groupPosts(posts: typeof sorted) {
  const now = new Date();
  const groups: Record<string, typeof sorted> = {};

  for (const post of posts) {
    const diff = (now.valueOf() - new Date(post.data.date).valueOf()) / 86400000;
    const label = diff < 1 ? '今天' : diff < 7 ? '本週' : diff < 30 ? '本月' : '更早';
    (groups[label] ??= []).push(post);
  }

  return groups;
}

const groups = groupPosts(sorted);
const ORDER = ['今天', '本週', '本月', '更早'];

const allTags = [...new Set(sorted.flatMap(p => p.data.tags))];
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="Jasper cowork with AI" href={`${siteUrl}/rss.xml`} />

  <!-- Open Graph -->
  <meta property="og:type" content={activeSlug ? 'article' : 'website'} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Jasper cowork with AI" />
  {date && <meta property="article:published_time" content={date} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={jsonLd} />

  <!-- Raw markdown alternate (AEO: AI crawlers can read plain markdown directly) -->
  {activeSlug && <link rel="alternate" type="text/markdown" href={`${canonicalUrl}.md`} title="Raw Markdown" />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body style="display:flex;height:100dvh;overflow:hidden;">
  {activeSlug && <div id="reading-progress" style="position:fixed;top:0;left:0;height:3px;width:0%;background:#60a5fa;z-index:1000;transition:width 0.08s linear;pointer-events:none;"></div>}

  <div id="sidebar-backdrop"></div>

  <!-- Sidebar -->
  <aside
    id="sidebar"
    style="
      width: 260px;
      flex-shrink: 0;
      background: var(--sidebar);
      border-right: 1px solid var(--border);
      flex-direction: column;
      transition: transform 0.2s ease;
    "
  >
    <!-- Blog name -->
    <div style="border-bottom: 1px solid var(--border); flex-shrink: 0;">
      <a
        href={base}
        style="display: block; padding: 16px; font-size: 16px; font-weight: 700; color: var(--text); text-decoration: none; letter-spacing: -0.02em;"
      >
        Jasper cowork with AI
      </a>
    </div>

    <!-- Article list -->
    <nav style="flex: 1; overflow-y: auto; padding: 8px 4px;">
      <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; padding: 8px 12px 4px;">Posts</div>
      {sorted.map(post => (
        <a
          href={`${base}posts/${post.id}`}
          style={`
            display: block;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 13px;
            color: ${activeSlug === post.id ? 'var(--text)' : 'var(--muted)'};
            background: ${activeSlug === post.id ? 'var(--border)' : 'transparent'};
            text-decoration: none;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: background 0.1s;
          `}
        >
          {post.data.title}
        </a>
      ))}
    </nav>

    <!-- Tags -->
    {allTags.length > 0 && (
      <div style="padding: 12px; border-top: 1px solid var(--border); flex-shrink: 0;">
        <div style="font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px;">Tags</div>
        <div style="display: flex; flex-wrap: wrap; gap: 6px;">
          {allTags.map(tag => (
            <a href={`${base}tags/${tag}`} style="font-size: 14px; color: #60a5fa; text-decoration: none;">
              #{tag}
            </a>
          ))}
        </div>
      </div>
    )}
  </aside>

  <!-- Main -->
  <div style="flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0;">

    <!-- Topbar -->
    <header style="
      height: 48px;
      flex-shrink: 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 12px;
    ">
      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        style="
          display: none;
          background: none;
          border: none;
          cursor: pointer;
          color: var(--muted);
          padding: 4px;
          flex-shrink: 0;
        "
        aria-label="Menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <!-- Mobile blog title (visible only on mobile) -->
      <a
        id="mobile-blog-title"
        href={base}
        style="display: none; font-size: 15px; font-weight: 700; color: var(--text); text-decoration: none; letter-spacing: -0.02em; flex-shrink: 0;"
      >
        Jasper cowork with AI
      </a>

      <!-- Title (article title, desktop only) -->
      <span id="topbar-title" style="flex: 1; font-size: 13px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
        {title ?? ''}
      </span>

      <!-- Icons -->
      <div style="display: flex; gap: 8px; flex-shrink: 0;">
        {title && (
          <>
            <button
              id="share-btn"
              style="background: none; border: none; cursor: pointer; color: var(--muted); padding: 4px; border-radius: 4px; display: flex; align-items: center;"
              title="複製連結"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
            </button>
            <a
              href={activeSlug ? `${base}posts/${activeSlug}.md` : '#'}
              style="background: none; border: none; cursor: pointer; color: var(--muted); padding: 4px; border-radius: 4px; display: flex; align-items: center; text-decoration: none;"
              title="Raw Markdown"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            </a>
          </>
        )}
        <a
          href={`${base}rss.xml`}
          style="background: none; border: none; cursor: pointer; color: var(--muted); padding: 4px; border-radius: 4px; display: flex; align-items: center; text-decoration: none;"
          title="RSS Feed"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- Content -->
    <main style="flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch;">
      <div class="content-wrapper">
        <slot />
      </div>
    </main>
  </div>

</body>
</html>

<style>
  /* RWD content width */
  .content-wrapper {
    width: 100%;
    max-width: 740px;
    margin: 0 auto;
    padding: 32px 16px;
  }

  @media (min-width: 640px) {
    .content-wrapper { padding: 40px 24px; }
  }

  @media (min-width: 1024px) {
    .content-wrapper { padding: 48px 32px; }
  }

  #sidebar { display: flex; }

  @media (max-width: 768px) {
    #sidebar {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      height: 100%;
      z-index: 100;
    }
    #sidebar.open { display: flex; }
    #menu-btn { display: flex !important; }
    #mobile-blog-title { display: block !important; flex: 1; }
    #topbar-title { display: none; }
    #sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 99;
    }
    #sidebar-backdrop.open { display: block; }
  }

  nav a:hover {
    background: var(--surface) !important;
    color: var(--text) !important;
  }

  #share-btn:hover, a[title="Raw Markdown"]:hover {
    background: var(--surface) !important;
    color: var(--text) !important;
  }
</style>

<script>
  document.getElementById('share-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(window.location.href);
  });

  function toggleSidebar() {
    document.getElementById('sidebar')?.classList.toggle('open');
    document.getElementById('sidebar-backdrop')?.classList.toggle('open');
  }
  document.getElementById('menu-btn')?.addEventListener('click', toggleSidebar);
  document.getElementById('sidebar-backdrop')?.addEventListener('click', toggleSidebar);

  const main = document.querySelector('main');
  const bar = document.getElementById('reading-progress');
  if (main && bar) {
    main.addEventListener('scroll', () => {
      const { scrollTop, scrollHeight, clientHeight } = main;
      const pct = scrollHeight <= clientHeight ? 100 : (scrollTop / (scrollHeight - clientHeight)) * 100;
      (bar as HTMLElement).style.width = pct + '%';
    });
  }
</script>
