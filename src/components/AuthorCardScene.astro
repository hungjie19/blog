---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="author-card">
  <div class="author-image-wrap">
    <img
      src={`${base}author-card.jpg`}
      alt="Jasper Hung coworking with AI"
      class="author-scene"
    />
  </div>
  <div class="author-info">
    <div class="author-name">Jasper Hung</div>
    <div class="author-role">Coworking with AI</div>
    <div class="author-bio">軟體工程師。記錄工程、產品與個人品牌的思考與實踐。</div>
    <div class="author-links">
      <a href={`${base}about`}>About</a>
      <a href="https://github.com/hungjie19" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</div>

<style>
  .author-card {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-top: 48px;
    border-top: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    overflow: hidden;
  }

  .author-image-wrap {
    flex-shrink: 0;
    width: 160px;
  }

  .author-scene {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .author-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .author-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .author-role {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .author-bio {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .author-links {
    display: flex;
    gap: 12px;
  }

  .author-links a {
    font-size: 13px;
    color: #60a5fa;
    text-decoration: none;
  }

  .author-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .author-card {
      flex-direction: column;
    }

    .author-image-wrap {
      width: 100%;
      height: 180px;
    }

    .author-scene {
      object-position: center 65%;
    }
  }
</style>
