---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="author-card">
  <img
    src={`${base}favicon.svg`}
    alt="Jasper Hung"
    class="author-avatar"
  />
  <div class="author-info">
    <div class="author-name">Jasper Hung</div>
    <div class="author-role">Software Engineer</div>
    <div class="author-bio">與 AI 協作的實戰紀錄：工程、產品、個人品牌。</div>
    <div class="author-links">
      <a href={`${base}about`}>About</a>
      <a href="https://github.com/hungjie19" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</div>

<style>
  .author-card {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    margin-top: 48px;
    padding: 24px;
    border-top: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
  }

  .author-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .author-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .author-role {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .author-bio {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .author-links {
    display: flex;
    gap: 12px;
  }

  .author-links a {
    font-size: 13px;
    color: #60a5fa;
    text-decoration: none;
  }

  .author-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .author-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
