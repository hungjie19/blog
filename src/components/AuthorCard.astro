---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="author-bio-card">
  <img
    src={`${base}author-avatar.jpg`}
    alt="Jasper Hung"
    class="author-avatar"
  />
  <div class="author-info">
    <div class="author-name">Jasper Hung</div>
    <div class="author-role">Coworking with AI</div>
    <div class="author-bio">軟體工程師。記錄工程、產品與個人品牌的思考與實踐。</div>
    <div class="author-links">
      <a href={`${base}about`}>About</a>
      <a href="https://github.com/hungjie19" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</div>

<style>
  .author-bio-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-top: 48px;
    padding: 20px;
    border-top: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
  }

  .author-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 50%;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }

  .author-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 4px;
  }

  .author-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 2px;
  }

  .author-role {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .author-bio {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .author-links {
    display: flex;
    gap: 12px;
  }

  .author-links a {
    font-size: 13px;
    color: #60a5fa;
    text-decoration: none;
  }

  .author-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .author-bio-card {
      flex-direction: column;
    }
  }
</style>
