---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<div class="author-bio-card">
  <img
    src={`${base}author-avatar.png`}
    alt="Jasper Hung"
    class="author-avatar"
  />
  <div class="author-info">
    <div class="author-name">Jasper Hung</div>
    <div class="author-role">Coworking with AI</div>
    <div class="author-bio">軟體工程師。記錄工程、產品與個人品牌的思考與實踐。</div>
    <div class="author-links">
      <a href={`${base}about`}>About</a>
      <a href="https://github.com/hungjie19" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</div>

<style>
  .author-bio-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-top: 48px;
    padding: 20px 22px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    box-shadow: none;
  }

  :global(html.dark) .author-bio-card {
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.16);
  }

  .author-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 50%;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }

  .author-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 4px;
  }

  .author-name {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.25;
    color: var(--text);
    margin-bottom: 4px;
  }

  .author-role {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .author-bio {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 12px;
  }

  .author-links {
    display: flex;
    gap: 12px;
  }

  .author-links a {
    font-size: 14px;
    color: var(--accent);
    text-decoration: none;
  }

  .author-links a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .author-bio-card {
      gap: 14px;
      padding: 18px;
    }

    .author-avatar {
      width: 72px;
      height: 72px;
    }
  }
</style>
